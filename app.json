{
  "expo": {
    "name": "Cardy Wall",
    "slug": "cardy-wall",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/cc-round.png",
    "scheme": "cardywall",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redonelabs.cardywall",
      "buildNumber": "6",
      "infoPlist": {
        "UIBackgroundModes": [],
        "NSFaceIDUsageDescription": "Allow Cardy Wall to use Face ID for securing your cards",
        "NSCameraUsageDescription": "Allow Cardy Wall to use your camera to scan cards, ID documents, and QR codes for secure sharing",
        "NSPhotoLibraryUsageDescription": "Allow Cardy Wall to access your photo library to upload ID documents and share QR codes",
        "NSPhotoLibraryAddUsageDescription": "Allow Cardy Wall to save processed ID documents to your library",
        "NSUserTrackingUsageDescription": "Allow Cardy Wall to track your activity to show more relevant and personalized ads for a better experience"
      },
      "appleTeamId": "743LUN242B"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/cc.png",
        "monochromeImage": "./assets/images/credit-card-mono.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.redonelabs.cardywall",
      "versionCode": 6,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "cardywall"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/cc.png",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "android_app_id": "ca-app-pub-4699580064236799~8493755965",
          "ios_app_id": "ca-app-pub-4699580064236799~6045744843"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos to your library",
          "isStandardAndroidLibrary": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/cc-round.png",
          "color": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}